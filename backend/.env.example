# ========================================
# CONFIGURACIÓN DEL SERVIDOR
# ========================================
PORT=3001
NODE_ENV=development

# ========================================
# BASE DE DATOS - PostgreSQL
# ========================================
# ⚠️ IMPORTANTE: Nunca commits credenciales reales a Git
# Obtén estas credenciales de tu proveedor de DB (Supabase, Railway, etc.)
DB_HOST=your_database_host_here
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# ========================================
# JWT - AUTENTICACIÓN
# ========================================
# ⚠️ IMPORTANTE: Genera una clave única y segura para producción
# Puedes generar una con: openssl rand -base64 64
JWT_SECRET=generate_a_secure_random_string_at_least_32_chars
JWT_EXPIRES_IN=24h

# ========================================
# SCRIPTS DE UTILIDAD (OPCIONAL)
# ========================================
# Solo necesario si ejecutas reset_admin_password.js
# NEW_ADMIN_PASSWORD=TuNuevaContraseñaSegura123!@

# ========================================
# CONFIGURACIÓN ADICIONAL (OPCIONAL)
# ========================================
# LOG_LEVEL=debug
# CORS_ORIGIN=http://localhost:3000
