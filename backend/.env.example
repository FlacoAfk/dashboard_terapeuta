# ========================================
# SERVIDOR
# ========================================
PORT=3001
NODE_ENV=development
JSON_BODY_LIMIT=2mb

# ========================================
# CORS
# Lista separada por comas
# ========================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# ========================================
# SEGURIDAD HTTP
# ========================================
HELMET_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300

# ========================================
# SUPABASE (REQUERIDO)
# ========================================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ========================================
# JWT (REQUERIDO)
# ========================================
JWT_SECRET=generate_a_secure_random_string_at_least_32_chars
JWT_EXPIRES_IN=24h

# ========================================
# UNITY API KEY (REQUERIDO)
# ========================================
UNITY_API_KEY=replace_with_secure_unity_api_key

# ========================================
# SMTP (REQUERIDO PARA RESET PASSWORD)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password
SMTP_FROM="Cerebro al Fuego" <your_email@example.com>

# ========================================
# REDIS (OPCIONAL)
# ========================================
REDIS_CACHE_ENABLED=true
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CONNECT_TIMEOUT_MS=3000

# ========================================
# AUTENTICACIÓN - BLOQUEO DE LOGIN
# ========================================
AUTH_MAX_ATTEMPTS=5
AUTH_LOCK_DURATION_MS=900000