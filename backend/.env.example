# ========================================
# CONFIGURACIÓN DEL SERVIDOR
# ========================================
PORT=3001
NODE_ENV=development

# ========================================
# BASE DE DATOS - PostgreSQL (Supabase)
# ========================================
# Obtén estas credenciales de tu proyecto en Supabase:
# https://app.supabase.com → Settings → Database
DB_HOST=db.xxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=tu_password_seguro

# ========================================
# JWT - AUTENTICACIÓN
# ========================================
# Genera una clave secreta segura para producción
# Puedes usar: openssl rand -base64 32
JWT_SECRET=tu_clave_secreta_muy_larga_y_segura_aqui_2024
JWT_EXPIRES_IN=24h

# ========================================
# CONFIGURACIÓN ADICIONAL (OPCIONAL)
# ========================================
# LOG_LEVEL=debug
# CORS_ORIGIN=http://localhost:3000
