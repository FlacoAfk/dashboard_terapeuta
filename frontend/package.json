{
    "name": "sistema-clinico-vr-frontend",
    "version": "1.8.5",
    "description": "Sistema Clínico VR - Dashboard Terapeuta (Electron + React)",
    "main": "dist-electron/main/main.js",
    "scripts": {
        "dev": "electron-vite dev",
        "dev:web": "vite --config vite.web.config.js",
        "build": "electron-vite build",
        "build:web": "vite build --config vite.web.config.js && node scripts/postbuild-web.js",
        "preview": "electron-vite preview",
        "preview:web": "vite preview --config vite.web.config.js",
        "start": "electron-vite preview",
        "lint": "eslint src --ext .js,.jsx",
        "test": "vitest run"
    },
    "dependencies": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-router-dom": "^7.1.1",
        "sweetalert2": "^11.26.17"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.1.0",
        "@testing-library/jest-dom": "^6.7.0",
        "@testing-library/react": "^16.3.0",
        "@vitejs/plugin-react": "^4.3.4",
        "autoprefixer": "^10.4.20",
        "electron": "^40.1.0",
        "electron-vite": "^5.0.0",
        "jsdom": "^26.1.0",
        "postcss": "^8.4.49",
        "tailwindcss": "^4.1.0",
        "vite": "^6.0.6",
        "vitest": "^2.1.9"
    },
    "keywords": [
        "electron",
        "react",
        "vite",
        "tailwindcss",
        "dashboard",
        "terapeuta"
    ],
    "author": "",
    "license": "ISC"
}
